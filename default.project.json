{
  "name": "JellyMonsterCircle",
  "tree": {
    "$className": "DataModel",

    "ReplicatedStorage": {
      "$className": "ReplicatedStorage",
      "Shared": {
        "$path": "src/ReplicatedStorage/Shared"
      },
      "Assets": {
        "$className": "Folder"
      }
    },

    "ServerScriptService": {
      "$className": "ServerScriptService",
      "Main": {
        "$path": "src/ServerScriptService/Main.server.lua"
      },
      "Modules": {
        "$path": "src/ServerScriptService/Modules"
      }
    },

    "StarterPlayer": {
      "$className": "StarterPlayer",
      "StarterPlayerScripts": {
        "$path": "src/StarterPlayer/StarterPlayerScripts"
      },
      "StarterCharacterScripts": {
        "$path": "src/StarterPlayer/StarterCharacterScripts"
      }
    },

    "Workspace": {
      "$className": "Workspace",
      "$properties": {
        "Gravity": 196.2,
        "FilteringEnabled": true
      }
    },

    "Lighting": {
      "$className": "Lighting",
      "$properties": {
        "Technology": "Future",
        "GlobalShadows": true,
        "ShadowSoftness": 0.5,
        "EnvironmentDiffuseScale": 0.5,
        "EnvironmentSpecularScale": 0.5
      }
    },

    "SoundService": {
      "$className": "SoundService",
      "$properties": {
        "RespectFilteringEnabled": true
      }
    },

    "HttpService": {
      "$className": "HttpService",
      "$properties": {
        "HttpEnabled": true
      }
    },

    "Players": {
      "$className": "Players",
      "$properties": {
        "CharacterAutoLoads": true
      }
    }
  }
}
